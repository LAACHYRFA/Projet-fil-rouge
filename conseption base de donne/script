CREATE DATABASE salle_de_sport;
USE salle_de_sport;
 
CREATE TABLE admin (
  id_admin   INT          NOT NULL AUTO_INCREMENT,
  username   VARCHAR(50)  NOT NULL UNIQUE,
  password   VARCHAR(255) NOT NULL,
  PRIMARY KEY (id_admin)
);
 
CREATE TABLE equipement (
  id_eq      INT          NOT NULL AUTO_INCREMENT,
  id_admin   INT          NOT NULL,
  nom        VARCHAR(100) NOT NULL,
  image      VARCHAR(255),
  categorie  VARCHAR(50)  NOT NULL,
  quantite   INT          NOT NULL DEFAULT 0,
  etat       ENUM('bon','en_reparation','hors_service') NOT NULL DEFAULT 'bon',
  PRIMARY KEY (id_eq),
  CONSTRAINT fk_eq_admin FOREIGN KEY (id_admin) REFERENCES admin(id_admin)
    ON UPDATE CASCADE ON DELETE RESTRICT
);
 
CREATE TABLE coach (
  id_coach     INT          NOT NULL AUTO_INCREMENT,
  id_admin     INT          NOT NULL,
  nom_complet  VARCHAR(100) NOT NULL,
  image        VARCHAR(255),
  specialite   VARCHAR(100) NOT NULL,
  telephone    VARCHAR(20),
  PRIMARY KEY (id_coach),
  CONSTRAINT fk_coach_admin FOREIGN KEY (id_admin) REFERENCES admin(id_admin)
    ON UPDATE CASCADE ON DELETE RESTRICT
);
 
CREATE TABLE abonnement (
  id_ab       INT           NOT NULL AUTO_INCREMENT,
  id_admin    INT           NOT NULL,
  titre       VARCHAR(100)  NOT NULL,
  prix        DECIMAL(10,2) NOT NULL,
  description TEXT,
  PRIMARY KEY (id_ab),
  CONSTRAINT fk_ab_admin FOREIGN KEY (id_admin) REFERENCES admin(id_admin)
    ON UPDATE CASCADE ON DELETE RESTRICT
);
 
CREATE TABLE utilisateur (
  id_utilisateur  INT          NOT NULL AUTO_INCREMENT,
  id_ab           INT          NOT NULL,
  nom_complet     VARCHAR(100) NOT NULL,
  email           VARCHAR(150) NOT NULL ,
  password        VARCHAR(255) NOT NULL,
  telephone       VARCHAR(20),
  photo           VARCHAR(255),
  date_inscription DATE    NOT NULL DEFAULT (CURRENT_DATE),
  PRIMARY KEY (id_utilisateur),
  CONSTRAINT fk_user_ab FOREIGN KEY (id_ab) REFERENCES abonnement(id_ab)
    ON UPDATE CASCADE ON DELETE RESTRICT
);
 
CREATE TABLE message (
  id_msg     INT          NOT NULL AUTO_INCREMENT,
  id_admin   INT          NOT NULL,
  nom        VARCHAR(100) NOT NULL,
  email      VARCHAR(150) NOT NULL,
  contenu    TEXT         NOT NULL,
  date_envoi DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (id_msg),
  CONSTRAINT fk_msg_admin FOREIGN KEY (id_admin) REFERENCES admin(id_admin)
    ON UPDATE CASCADE ON DELETE RESTRICT
);
 