CREATE DATABASE salle_de_sport;
USE salle_de_sport;

-- ADMIN
CREATE TABLE admin (
  id_admin INT PRIMARY KEY AUTO_INCREMENT,
  username VARCHAR(50) NOT NULL UNIQUE,
  password VARCHAR(255) NOT NULL
);

-- EQUIPEMENT
CREATE TABLE equipement (
  id_eq INT PRIMARY KEY AUTO_INCREMENT,
  id_admin INT NOT NULL,
  nom VARCHAR(100) NOT NULL,
  image VARCHAR(255),
  categorie VARCHAR(50) NOT NULL,
  quantite INT NOT NULL DEFAULT 0,
  etat ENUM('bon','en_reparation','hors_service') NOT NULL DEFAULT 'bon',

  FOREIGN KEY (id_admin) REFERENCES admin(id_admin)
  ON UPDATE CASCADE ON DELETE RESTRICT
);

-- COACH
CREATE TABLE coach (
  id_coach INT PRIMARY KEY AUTO_INCREMENT,
  id_admin INT NOT NULL,
  nom_complet VARCHAR(100) NOT NULL,
  image VARCHAR(255),
  specialite VARCHAR(100) NOT NULL,
  telephone VARCHAR(20),

  FOREIGN KEY (id_admin) REFERENCES admin(id_admin)
  ON UPDATE CASCADE ON DELETE RESTRICT
);

-- ABONNEMENT
CREATE TABLE abonnement (
  id_ab INT PRIMARY KEY AUTO_INCREMENT,
  id_admin INT NOT NULL,
  titre VARCHAR(100) NOT NULL,
  prix DECIMAL(10,2) NOT NULL,
  description TEXT,

  FOREIGN KEY (id_admin) REFERENCES admin(id_admin)
  ON UPDATE CASCADE ON DELETE RESTRICT
);

-- UTILISATEUR
CREATE TABLE utilisateur (
  id_utilisateur INT PRIMARY KEY AUTO_INCREMENT,
  id_ab INT NOT NULL,
  nom_complet VARCHAR(100) NOT NULL,
  email VARCHAR(150) NOT NULL,
  password VARCHAR(255) NOT NULL,
  telephone VARCHAR(20),
  date_inscription DATE DEFAULT CURRENT_DATE,

  FOREIGN KEY (id_ab) REFERENCES abonnement(id_ab)
  ON UPDATE CASCADE ON DELETE RESTRICT
);

-- MESSAGE
CREATE TABLE message (
  id_msg INT PRIMARY KEY AUTO_INCREMENT,
  id_admin INT NOT NULL,
  nom VARCHAR(100) NOT NULL,
  email VARCHAR(150) NOT NULL,
  contenu TEXT NOT NULL,
  date_envoi DATETIME DEFAULT CURRENT_TIMESTAMP,

  FOREIGN KEY (id_admin) REFERENCES admin(id_admin)
  ON UPDATE CASCADE ON DELETE RESTRICT
);
